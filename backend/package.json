{
  "name": "eventos-academicos-backend",
  "version": "1.0.0",
  "description": "API REST (Node + Express, arquitetura MVC) para site de eventos academicos.",
  "main": "src/server.js",
  "type": "commonjs",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "db:migrate": "node src/database/migrate.js",
    "db:seed": "node src/database/seed.js",
    "db:reset": "node src/database/migrate.js && node src/database/seed.js",
    "test": "jest --runInBand",
    "test:coverage": "jest --runInBand --coverage",
    "sonar": "sonar-scanner"
  },
  "keywords": [
    "eventos",
    "academico",
    "express",
    "mvc",
    "api"
  ],
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "pg": "^8.22.0",
    "supertest": "^7.0.0"
  }
}
